{
  "$schema": "https://getcomposer.org/schema.json",
  "name": "jason/saas",
  "type": "project",
  "description": "Jason.Chen's Laravel&Filament project",
  "keywords": [
    "laravel",
    "framework"
  ],
  "license": "MIT",
  "require": {
    "php": "^8.5",
    "ext-bcmath": "*",
    "ext-gmp": "*",
    "ext-openssl": "*",
    "ext-pdo": "*",
    "ext-zip": "*",
    "aliyuncs/oss-sdk-php": "^2.7",
    "codewithdennis/filament-select-tree": "^4.0",
    "deldius/filament-user-field": "^1.1",
    "diogogpinto/filament-auth-ui-enhancer": "^2.0",
    "filament/filament": "^5.1",
    "flowframe/laravel-trend": "^0.4.0",
    "genealabs/laravel-model-caching": "^12.0",
    "kornrunner/keccak": "^1.1",
    "laravel-lang/common": "^6.7",
    "laravel/framework": "^12.51",
    "laravel/horizon": "^5.44",
    "laravel/octane": "^2.13",
    "laravel/sanctum": "^4.3",
    "laravel/tinker": "^2.11",
    "league/flysystem-aws-s3-v3": "^3.31",
    "maatwebsite/excel": "^3.1",
    "malzariey/filament-daterangepicker-filter": "^4.0",
    "mews/captcha": "^3.4",
    "nelexa/zip": "^4.0",
    "overtrue/easy-sms": "^3.3",
    "overtrue/laravel-wechat": "^7.4",
    "overtrue/pinyin": "^6.0",
    "overtrue/socialite": "^4.12",
    "simplito/elliptic-php": "^1.0",
    "tuupola/base58": "^2.2",
    "vinkla/hashids": "^13.0"
  },
  "require-dev": {
    "fakerphp/faker": "^1.24",
    "laravel/pail": "^1.2",
    "laravel/pint": "^1.27",
    "laravel/sail": "^1.53",
    "mockery/mockery": "^1.6",
    "nunomaduro/collision": "^8.8",
    "pestphp/pest": "^4.3",
    "pestphp/pest-plugin-laravel": "^4.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\Factories\\": "database/factories/",
      "Database\\Seeders\\": "database/seeders/"
    },
    "files": [
      "bootstrap/helpers.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "setup": [
      "composer install",
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
      "@php artisan key:generate",
      "@php artisan migrate --force",
      "pnpm install",
      "pnpm run build"
    ],
    "dev": [
      "Composer\\Config::disableProcessTimeout",
      "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
    ],
    "test": [
      "@php artisan config:clear --ansi",
      "@php artisan test"
    ],
    "post-autoload-dump": [
      "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
      "@php artisan package:discover --ansi",
      "@php artisan filament:upgrade"
    ],
    "post-update-cmd": [
      "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
    ],
    "post-root-package-install": [
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
    ],
    "post-create-project-cmd": [
      "@php artisan key:generate --ansi",
      "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
      "@php artisan migrate --graceful --ansi"
    ],
    "pre-package-uninstall": [
      "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
    ]
  },
  "extra": {
    "laravel": {
      "dont-discover": []
    }
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true,
      "php-http/discovery": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
