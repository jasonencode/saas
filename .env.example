APP_NAME=Saas.Foundation
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://localhost
APP_TIMEZONE=Asia/Shanghai

APP_LOCALE=zh_CN
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=daily
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
LOG_DAILY_DAYS=30

# 数据库配置
DB_CONNECTION=pgsql
DB_HOST=postgresql
DB_PORT=5432
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

# Redis配置
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

VITE_APP_NAME="${APP_NAME}"

FILESYSTEM_DISK=public

# 阿里云 OSS
# OSS_ACCESS_KEY=
# OSS_SECRET_KEY=
# OSS_REGION=
# OSS_BUCKET=
# OSS_ENDPOINT=
# OSS_URL=

# MINIO 配置demo
# FILESYSTEM_DISK=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=
# AWS_BUCKET=
# AWS_URL=
# AWS_ENDPOINT=
# AWS_USE_PATH_STYLE_ENDPOINT=true

# 自定义配置
FORCE_HTTPS=true
SERVER_ID=MAIN
DEFAULT_DOMAIN=
API_DOMAIN=
BACKEND_DOMAIN=
TENANT_DOMAIN=

# 租户默认配置
TENANT_USER_PASSWORD=a123456

# 用户身份配置
# 是否允许用户同时拥有多个身份（true=可多身份叠加，false=同一时间只能有一个身份）
IDENTITY_ALLOW_MULTIPLE=false

# 商城配置
MALL_ORDER_EXPIRED_MINUTES=30

# 频率限制配置
RATE_LIMIT_API=60
RATE_LIMIT_UPLOAD=10
RATE_LIMIT_LOGIN=5
RATE_LIMIT_SMS=2
RATE_LIMIT_REGISTER=3
RATE_LIMIT_PASSWORD_RESET=3
RATE_LIMIT_DEFAULT=30

HASHID_SALT=Saas.Foundation
HASHID_LENGTH=6
HASHID_ALPHABET=ABCDEFGHIJKLMNOPQRSTUVWXYZ1234567890

OCTANE_SERVER=frankenphp
OCTANE_HTTPS=false

WECHAT_OFFICIAL_ACCOUNT_APPID=
WECHAT_OFFICIAL_ACCOUNT_SECRET=
WECHAT_OFFICIAL_ACCOUNT_TOKEN=
WECHAT_OFFICIAL_ACCOUNT_AES_KEY=
